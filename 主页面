-- 创建ESP
function createESP()
    if espRunning then return end
    espRunning = true
    clearESP()
    
    if not espEnabled then 
        espRunning = false
        return 
    end
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            addPlayerESP(player)
        end
    end
    
    espConnections.playerAdded = Players.PlayerAdded:Connect(function(player)
        player.CharacterAdded:Connect(function(character)
            if espEnabled then
                wait(1)
                addPlayerESP(player)
            end
        end)
    end)
    
    espConnections.playerRemoving = Players.PlayerRemoving:Connect(function(player)
        if espObjects[player.Name] then
            removePlayerESP(player.Name)
        end
    end)
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            espConnections[player.Name] = player.CharacterAdded:Connect(function(character)
                if espEnabled then
                    wait(1)
                    if espObjects[player.Name] then
                        removePlayerESP(player.Name)
                    end
                    addPlayerESP(player)
                end
            end)
        end
    end
    
    espConnections.updateLoop = game:GetService("RunService").Heartbeat:Connect(function(dt)
        if espEnabled then
            updateTimer = updateTimer + dt
            if updateTimer >= 1 then
                updateESP()
                updateTimer = 0
            end
        end
    end)
end

-- 添加玩家ESP
function addPlayerESP(player)
    if not player or not player.Character then return end
    
    local character = player.Character
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    
    if not humanoidRootPart then return end
    
    espObjects[player.Name] = {
        player = player,
        character = character,
        humanoidRootPart = humanoidRootPart,
        humanoid = humanoid,
        objects = {},
        tracers = {}
    }
    
    local playerData = espObjects[player.Name]
    local isFriend = isPlayerFriend(player)
    
    local highlight = Instance.new("Highlight")
    highlight.Name = "ESP_Highlight"
    highlight.Adornee = character
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.FillTransparency = 1
    highlight.OutlineTransparency = 0
    highlight.OutlineColor = isFriend and showTeamCheck and friendColor or enemyColor
    highlight.Parent = character
    table.insert(playerData.objects, highlight)
    
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ESP_Info"
    billboard.Adornee = humanoidRootPart
    billboard.AlwaysOnTop = true
    billboard.Size = UDim2.new(0, 200, 0, 60)
    billboard.StudsOffset = Vector3.new(0, 3.5, 0)
    billboard.ResetOnSpawn = false
    billboard.Parent = game:GetService("CoreGui")
    
    local container = Instance.new("Frame")
    container.Name = "Container"
    container.BackgroundTransparency = 1
    container.Size = UDim2.new(1, 0, 1, 0)
    container.Parent = billboard
    
    local distanceLabel = Instance.new("TextLabel")
    distanceLabel.Name = "DistanceLabel"
    distanceLabel.BackgroundTransparency = 1
    distanceLabel.Position = UDim2.new(0, 0, 0, 0)
    distanceLabel.Size = UDim2.new(1, 0, 0.5, 0)
    distanceLabel.Text = L("showDistance") .. ": " .. L("calculating")
    distanceLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
    distanceLabel.TextScaled = true
    distanceLabel.Font = Enum.Font.SourceSans
    distanceLabel.TextStrokeTransparency = 0
    distanceLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    distanceLabel.Visible = showDistance
    distanceLabel.Parent = container
    
    local healthLabel = Instance.new("TextLabel")
    healthLabel.Name = "HealthLabel"
    healthLabel.BackgroundTransparency = 1
    healthLabel.Position = UDim2.new(0, 0, 0.5, 0)
    healthLabel.Size = UDim2.new(1, 0, 0.5, 0)
    healthLabel.Text = L("showHealth") .. ": 100%"
    healthLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
    healthLabel.TextScaled = true
    healthLabel.Font = Enum.Font.SourceSans
    healthLabel.TextStrokeTransparency = 0
    healthLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    healthLabel.Visible = showHealth
    healthLabel.Parent = container
    
    table.insert(playerData.objects, billboard)
    
    espConnections[player.Name.."_destroy"] = character.Destroying:Connect(function()
        if espObjects[player.Name] then
            removePlayerESP(player.Name)
        end
    end)
    
    if humanoid then
        espConnections[player.Name.."_health"] = humanoid:GetPropertyChangedSignal("Health"):Connect(function()
        end)
    end
end

-- 移除玩家ESP
function removePlayerESP(playerName)
    if espObjects[playerName] then
        for _, obj in pairs(espObjects[playerName].objects) do
            if obj and obj.Parent then
                obj:Destroy()
            end
        end
        espObjects[playerName] = nil
    end
end

-- 清除所有ESP
function clearESP()
    espRunning = false
    for playerName, _ in pairs(espObjects) do
        removePlayerESP(playerName)
    end
    espObjects = {}
    
    for name, connection in pairs(espConnections) do
        if connection then
            connection:Disconnect()
        end
    end
    espConnections = {}
end

-- 更新ESP
function updateESP()
    if not espEnabled or not espRunning then return end
    
    for playerName, playerData in pairs(espObjects) do
        if playerData.character and playerData.humanoidRootPart then
            if playerData.objects[2] and playerData.objects[2]:FindFirstChild("Container") then
                local container = playerData.objects[2].Container
                local distanceLabel = container:FindFirstChild("DistanceLabel")
                local healthLabel = container:FindFirstChild("HealthLabel")
                
                if distanceLabel then
                    local localCharacter = LocalPlayer.Character
                    if localCharacter and localCharacter:FindFirstChild("HumanoidRootPart") then
                        local distance = (playerData.humanoidRootPart.Position - localCharacter.HumanoidRootPart.Position).Magnitude
                        local distanceInGrid = math.floor(distance / 4)
                        distanceLabel.Text = L("showDistance") .. ": " .. distanceInGrid .. " 格"
                        distanceLabel.Visible = showDistance
                    else
                        distanceLabel.Visible = false
                    end
                end
                
                if healthLabel and playerData.humanoid then
                    local healthPercent = math.floor((playerData.humanoid.Health / playerData.humanoid.MaxHealth) * 100)
                    healthLabel.Text = L("showHealth") .. ": " .. healthPercent .. "% (" .. math.floor(playerData.humanoid.Health) .. "/" .. math.floor(playerData.humanoid.MaxHealth) .. ")"
                    healthLabel.Visible = showHealth
                end
            end
            
            if playerData.objects[1] and playerData.objects[1]:IsA("Highlight") then
                local isFriend = isPlayerFriend(playerData.player)
                playerData.objects[1].OutlineColor = isFriend and showTeamCheck and friendColor or enemyColor
            end
            
            if showTracers then
                updateTracer(playerName)
            else
                removeTracer(playerName)
            end
        end
    end
end

-- 创建追踪线
function updateTracer(playerName)
    if not espObjects[playerName] then return end
    
    local playerData = espObjects[playerName]
    local character = playerData.character
    if not character then return end
    
    removeTracer(playerName)
    
    local camera = game:GetService("Workspace").CurrentCamera
    if not camera then return end
    
    local humanoidRootPart = playerData.humanoidRootPart
    if not humanoidRootPart then return end
    
    local startPoint
    if tracerStartPoint == "bottom" then
        startPoint = Vector3.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y, 0)
    else
        startPoint = Vector3.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2, 0)
    end
    
    local playerPos, onScreen = camera:WorldToViewportPoint(humanoidRootPart.Position)
    
    if onScreen then
        local isFriend = isPlayerFriend(playerData.player)
        local color = isFriend and showTeamCheck and friendColor or enemyColor
        
        local line = Instance.new("LineHandleAdornment")
        line.Name = "ESP_Tracer"
        line.Color3 = color
        line.Transparency = 0.8
        line.Thickness = 2
        line.ZIndex = 5
        line.Length = (Vector3.new(playerPos.X, playerPos.Y, 0) - startPoint).Magnitude
        line.CFrame = CFrame.lookAt(startPoint, Vector3.new(playerPos.X, playerPos.Y, 0)) * CFrame.new(0, 0, -line.Length/2)
        line.Parent = game:GetService("CoreGui")
        
        table.insert(playerData.objects, line)
        table.insert(playerData.tracers, line)
    end
end

-- 移除追踪线
function removeTracer(playerName)
    if not espObjects[playerName] then return end
    
    local playerData = espObjects[playerName]
    if playerData.tracers then
        for _, line in pairs(playerData.tracers) do
            if line and line.Parent then
                line:Destroy()
            end
        end
        playerData.tracers = {}
    end
end

-- 检查玩家是否是友方
function isPlayerFriend(player)
    if not showTeamCheck then return false end
    
    if LocalPlayer.Team and player.Team then
        return LocalPlayer.Team == player.Team
    end
    
    local success, isFriend = pcall(function()
        return player:IsFriendsWith(LocalPlayer.UserId)
    end)
    
    if success then
        return isFriend
    end
    
    return false
end

