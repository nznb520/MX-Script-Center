-- 爬墙功能
local climbToggle = Tabs.GeneralTab:Toggle({
    Title = L("climb"),
    Desc = L("climbDesc"),
    Value = false,
    Callback = function(state)
        climbEnabled = state
        print("爬墙模式: " .. tostring(state))
        
        if state then
            local player = LocalPlayer
            local userInputService = game:GetService("UserInputService")
            
            climbConnection = game:GetService("RunService").Heartbeat:Connect(function()
                if not climbEnabled then return end
                
                local character = player.Character
                if not character then return end
                
                local humanoid = character:FindFirstChildOfClass("Humanoid")
                local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
                
                if not humanoid or not humanoidRootPart then return end
                
                local isMovingForward = userInputService:IsKeyDown(Enum.KeyCode.W)
                local isTouchingWall = false
                
                local raycastParams = RaycastParams.new()
                raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
                raycastParams.FilterDescendantsInstances = {character}
                
                local rayDirection = character.HumanoidRootPart.CFrame.LookVector * 3
                local rayResult = workspace:Raycast(humanoidRootPart.Position, rayDirection, raycastParams)
                
                if rayResult then
                    isTouchingWall = true
                end
                
                if isTouchingWall and isMovingForward then
                    humanoidRootPart.Velocity = Vector3.new(humanoidRootPart.Velocity.X, 16, humanoidRootPart.Velocity.Z)
                end
            end)
        else
            if climbConnection then
                climbConnection:Disconnect()
                climbConnection = nil
            end
        end
    end
})

